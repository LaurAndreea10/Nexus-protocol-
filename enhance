#story-d.on{display:block;animation:dIn .4s ease}
@keyframes dIn{from{opacity:0;transform:translateX(-50%) translateY(12px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
.sp{font-family:var(--fM);font-size:11px;color:var(--cy);letter-spacing:.2em;text-transform:uppercase;margin-bottom:6px}
.st{color:var(--t0);font-size:14px;line-height:1.5}
.sc{margin-top:12px;display:grid;gap:6px}
.sch{background:rgba(0,240,255,.06);border:1px solid rgba(0,240,255,.3);color:var(--t0);padding:9px 13px;font-family:var(--fM);font-size:12px;text-align:left;cursor:pointer;pointer-events:auto;transition:all .15s}
.sch:hover{background:rgba(0,240,255,.15);border-color:var(--cy);transform:translateX(4px)}
.ovl{position:absolute;inset:0;z-index:10;background:radial-gradient(ellipse at center,rgba(10,15,31,.85),rgba(5,7,15,.97));backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;padding:20px}
.ovl.on{display:flex}
.ovl.on .pn{animation:pIn .5s cubic-bezier(.16,1,.3,1)}
@keyframes pIn{from{opacity:0;transform:translateY(20px) scale(.96)}to{opacity:1;transform:translateY(0) scale(1)}}
.pn{position:relative;max-width:820px;width:100%;max-height:90vh;overflow-y:auto;background:linear-gradient(135deg,rgba(17,24,53,.95),rgba(10,15,31,.95));border:1px solid rgba(0,240,255,.35);box-shadow:0 0 80px rgba(0,240,255,.15),inset 0 0 80px rgba(138,59,255,.06);padding:26px 32px;clip-path:polygon(0 0,calc(100% - 16px) 0,100% 16px,100% 100%,16px 100%,0 calc(100% - 16px))}
.pn::-webkit-scrollbar{width:6px}.pn::-webkit-scrollbar-track{background:rgba(0,0,0,.3)}.pn::-webkit-scrollbar-thumb{background:var(--cy)}
.pn.m{border-color:rgba(255,43,214,.4);box-shadow:0 0 80px rgba(255,43,214,.18)}
.pn.y{border-color:rgba(255,230,0,.4);box-shadow:0 0 80px rgba(255,230,0,.15)}
.pn.v{border-color:rgba(138,59,255,.4);box-shadow:0 0 80px rgba(138,59,255,.18)}
.pn h1,.pn h2,.pn h3{font-family:var(--fD);font-weight:900;letter-spacing:.04em;line-height:1.05}
.pn h1{font-size:clamp(26px,5vw,46px);background:linear-gradient(90deg,var(--cy),var(--mg) 60%,var(--vt));-webkit-background-clip:text;background-clip:text;color:transparent;margin-bottom:6px}
.pn h2{font-size:18px;color:var(--cy);text-shadow:var(--gC);margin:16px 0 10px}
.pn h3{font-size:13px;color:var(--t0);margin-bottom:8px}
.pn .sb{font-family:var(--fM);font-size:10px;color:var(--t1);letter-spacing:.2em;text-transform:uppercase;margin-bottom:16px}
.pn p{color:var(--t1);font-size:13px;line-height:1.6;margin-bottom:10px}
.btn{display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,var(--cy),var(--vt));color:var(--bg-0);font-family:var(--fD);font-weight:700;font-size:12px;letter-spacing:.14em;text-transform:uppercase;padding:11px 18px;border:none;cursor:pointer;clip-path:polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,8px 100%,0 calc(100% - 8px));transition:transform .15s,filter .2s;pointer-events:auto}
.btn:hover{transform:translateY(-2px);filter:brightness(1.15)}
.btn:disabled{opacity:.35;cursor:not-allowed;transform:none}
.btn.gh{background:transparent;color:var(--cy);border:1px solid var(--cy);box-shadow:var(--gC)}
.btn.mg{background:linear-gradient(135deg,var(--mg),var(--rd));color:var(--t0)}
.btn.yl{background:linear-gradient(135deg,var(--yl),var(--or));color:var(--bg-0)}
.tt{display:flex;gap:4px;margin-bottom:12px;border-bottom:1px solid rgba(0,240,255,.15);flex-wrap:wrap}
.tb{padding:7px 12px;font-family:var(--fM);font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:var(--t2);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s}
.tb.on{color:var(--cy);border-bottom-color:var(--cy)}
.tc{display:none}
.tc.on{display:block}
.tc.grid{display:none;grid-template-columns:1fr 1fr;gap:8px}
.tc.grid.on{display:grid}
.md{background:linear-gradient(135deg,rgba(0,240,255,.06),rgba(255,43,214,.06));border:1px solid rgba(0,240,255,.2);padding:10px 12px;cursor:pointer;transition:all .2s;position:relative}
.md:hover:not(.lk):not(.ow){border-color:var(--cy);background:linear-gradient(135deg,rgba(0,240,255,.15),rgba(255,43,214,.1))}
.md.ow{border-color:var(--gn);background:linear-gradient(135deg,rgba(57,255,126,.1),rgba(57,255,126,.04));cursor:default}
.md.lk{opacity:.35;cursor:not-allowed}
.mdt{position:absolute;top:6px;right:10px;font-family:var(--fM);font-size:9px;color:var(--vt);letter-spacing:.15em}
.mdn{font-family:var(--fD);font-weight:700;font-size:11px;color:var(--t0);letter-spacing:.06em;margin-bottom:3px}
.mdd{font-size:10px;color:var(--t2);line-height:1.4}
.mdc{font-family:var(--fM);font-size:10px;color:var(--yl);margin-top:5px}
.md.ow .mdc{color:var(--gn)}.md.ow .mdc::before{content:'✓ '}
.cb{background:var(--bg-0);border:1px solid var(--vt);padding:12px 14px;font-family:var(--fM);font-size:13px;color:var(--cy);margin:10px 0;line-height:1.6;box-shadow:inset 0 0 30px rgba(138,59,255,.15);white-space:pre-wrap;word-break:break-word}
.cb .kw{color:var(--mg)}.cb .str{color:var(--yl)}.cb .com{color:var(--t2);font-style:italic}.cb .num{color:var(--gn)}
.ca{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:8px}
.ab{background:rgba(10,15,31,.7);border:1px solid rgba(0,240,255,.3);color:var(--t0);font-family:var(--fM);font-size:11px;padding:9px 11px;cursor:pointer;text-align:left;transition:all .15s;pointer-events:auto}
.ab:hover{background:rgba(0,240,255,.1);border-color:var(--cy)}
.ab.cr{background:rgba(57,255,126,.2);border-color:var(--gn);color:var(--gn)}
.ab.wr{background:rgba(255,43,214,.2);border-color:var(--rd);color:var(--rd)}
.ct{height:3px;background:rgba(255,255,255,.1);margin:12px 0 4px;overflow:hidden}
.ctf{height:100%;background:linear-gradient(90deg,var(--gn),var(--yl),var(--rd));width:100%;transition:width .1s linear}
.cc{display:inline-block;font-family:var(--fM);font-size:9px;padding:3px 7px;background:rgba(255,230,0,.1);border:1px solid rgba(255,230,0,.3);color:var(--yl);letter-spacing:.15em;text-transform:uppercase;margin-bottom:6px}
.sg{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin:12px 0}
.s{background:rgba(0,240,255,.05);border:1px solid rgba(0,240,255,.2);padding:10px;text-align:center}
.sl{font-family:var(--fM);font-size:9px;color:var(--t2);letter-spacing:.15em;text-transform:uppercase}
.sv{font-family:var(--fD);font-weight:800;font-size:18px;color:var(--cy);text-shadow:var(--gC);margin-top:3px}
.lb{margin:10px 0;border:1px solid rgba(0,240,255,.2)}
.lbr{display:grid;grid-template-columns:28px 1fr 70px auto auto;gap:8px;padding:5px 10px;font-family:var(--fM);font-size:10px;border-bottom:1px solid rgba(0,240,255,.08);align-items:center}
.lbr:last-child{border-bottom:none}.lbr.you{background:rgba(255,230,0,.06);color:var(--yl)}
.lr{color:var(--t2)}.lr.g{color:var(--yl);font-weight:700}.lr.s2{color:#c0c8e0;font-weight:700}.lr.br{color:var(--or);font-weight:700}
.ln{color:var(--t0)}.ls{color:var(--cy)}
#tc{position:absolute;top:12px;right:14px;z-index:8;display:flex;gap:5px;pointer-events:auto}
.ib{width:28px;height:28px;background:rgba(10,15,31,.7);border:1px solid rgba(0,240,255,.3);color:var(--cy);font-family:var(--fM);font-size:10px;font-weight:700;cursor:pointer;display:grid;place-items:center;transition:all .15s}
.ib:hover{background:rgba(0,240,255,.15);border-color:var(--cy)}
.db{background:linear-gradient(90deg,rgba(255,230,0,.1),rgba(255,43,214,.1));border:1px solid rgba(255,230,0,.3);padding:9px 12px;margin:10px 0;font-family:var(--fM);font-size:11px;color:var(--yl);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px}
.ac{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px}
.kh{margin-top:10px;font-family:var(--fM);font-size:10px;color:var(--t2);letter-spacing:.1em;text-transform:uppercase;display:flex;gap:10px;flex-wrap:wrap}
.k{display:inline-block;padding:2px 7px;background:rgba(0,240,255,.08);border:1px solid rgba(0,240,255,.2);color:var(--cy);margin-right:3px}
.ag{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:6px;max-height:50vh;overflow-y:auto;padding-right:4px}
.a{background:rgba(255,255,255,.03);border:1px solid rgba(0,240,255,.1);padding:9px;font-size:10px;font-family:var(--fM);color:var(--t2)}
.a.u{border-color:var(--yl);background:rgba(255,230,0,.06);color:var(--yl)}
.ai{font-size:17px;margin-bottom:4px}
.fc{background:linear-gradient(135deg,rgba(10,15,31,.6),rgba(17,24,53,.6));border-left:3px solid;padding:10px 12px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;gap:8px}
.fci h4{font-family:var(--fD);font-size:12px;margin-bottom:3px}
.fci p{font-size:10px;margin:0;color:var(--t2)}
.frn{font-family:var(--fM);font-size:15px;font-weight:700;min-width:50px;text-align:right}
.cl{display:grid;gap:5px;max-height:50vh;overflow-y:auto}
.ch{display:grid;grid-template-columns:30px 1fr auto;gap:10px;padding:8px 12px;background:rgba(255,255,255,.03);border:1px solid rgba(0,240,255,.1);align-items:center;cursor:pointer;transition:all .15s}
.ch:not(.lk):hover{border-color:var(--cy);background:rgba(0,240,255,.06)}
.ch.lk{opacity:.4;cursor:not-allowed}
.ch.cm{border-color:rgba(57,255,126,.3)}
.chn{font-family:var(--fD);color:var(--cy);font-weight:700;font-size:13px}
.chnm{font-family:var(--fU);font-size:13px}
.chs{font-family:var(--fM);font-size:9px;color:var(--t2)}
.ch.cm .chs{color:var(--gn)}
.pt{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:8px}
.pn-n{background:linear-gradient(135deg,rgba(138,59,255,.1),rgba(255,43,214,.05));border:1px solid rgba(138,59,255,.3);padding:10px;cursor:pointer;transition:all .15s}
.pn-n:hover:not(.lk):not(.ow){border-color:var(--vt);transform:translateY(-2px)}
.pn-n.ow{border-color:var(--gn);background:rgba(57,255,126,.06)}
.pn-n.lk{opacity:.3;cursor:not-allowed}
#obj{position:absolute;top:52px;right:14px;background:rgba(10,15,31,.75);border:1px solid rgba(255,230,0,.3);padding:8px 12px;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);font-family:var(--fM);font-size:11px;z-index:5;display:none;max-width:240px}
#obj.on{display:block}
.ot{color:var(--yl);font-size:9px;letter-spacing:.2em;text-transform:uppercase;margin-bottom:4px}
.oi{color:var(--t1);padding:2px 0;font-size:11px}
.oi.dn{color:var(--gn);text-decoration:line-through}
#touch-ctrl{position:absolute;bottom:10px;left:0;right:0;z-index:6;display:none;justify-content:space-between;padding:0 20px;pointer-events:none}
.tbtn{width:56px;height:56px;background:rgba(10,15,31,.6);border:2px solid rgba(0,240,255,.4);color:var(--cy);font-size:22px;border-radius:50%;display:grid;place-items:center;pointer-events:auto;backdrop-filter:blur(6px)}
@media (hover:none) and (pointer:coarse){#touch-ctrl.show{display:flex}}
@media (max-width:720px){#game-frame{width:100vw;height:100vh;aspect-ratio:unset;border:none}.pn{padding:18px}.tc.grid.on,.sg,.ca{grid-template-columns:1fr}.hv{font-size:13px}#combo{font-size:32px;right:10px}.pn h1{font-size:24px}}
.vi{display:grid;gap:8px;margin:12px 0}
