<style>
:root{--bg-0:#05070f;--bg-1:#0a0f1f;--bg-2:#111835;--cy:#00f0ff;--mg:#ff2bd6;--vt:#8a3bff;--yl:#ffe600;--gn:#39ff7e;--rd:#ff3b6b;--or:#ff8c1a;--t0:#f4f7ff;--t1:#aab3d9;--t2:#6b7399;--t3:#4a5278;--gC:0 0 12px rgba(0,240,255,.6),0 0 32px rgba(0,240,255,.25);--gM:0 0 12px rgba(255,43,214,.6),0 0 32px rgba(255,43,214,.25);--gY:0 0 12px rgba(255,230,0,.6),0 0 32px rgba(255,230,0,.25);--gG:0 0 12px rgba(57,255,126,.55),0 0 28px rgba(57,255,126,.22);--gV:0 0 12px rgba(138,59,255,.6),0 0 32px rgba(138,59,255,.25);--fD:'Orbitron',sans-serif;--fU:'Rajdhani',sans-serif;--fM:'JetBrains Mono',monospace}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden;background:var(--bg-0);color:var(--t0);font-family:var(--fU);-webkit-font-smoothing:antialiased;user-select:none}
body{display:grid;place-items:center;background:radial-gradient(ellipse at 20% 0%,rgba(138,59,255,.18),transparent 50%),radial-gradient(ellipse at 80% 100%,rgba(0,240,255,.12),transparent 55%),radial-gradient(ellipse at 50% 50%,rgba(255,43,214,.08),transparent 60%),var(--bg-0)}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:100;opacity:.04;background-image:repeating-linear-gradient(0deg,rgba(255,255,255,.5) 0 1px,transparent 1px 3px);mix-blend-mode:overlay}
.scanlines::after{content:'';position:absolute;inset:0;pointer-events:none;background:repeating-linear-gradient(0deg,rgba(0,0,0,.15) 0 2px,transparent 2px 4px);z-index:2}
#game-frame{position:relative;width:min(100vw,1280px);height:min(100vh,840px);aspect-ratio:3/2;background:var(--bg-1);border:1px solid rgba(0,240,255,.2);box-shadow:0 0 0 1px rgba(255,43,214,.15),0 0 60px rgba(0,240,255,.18),inset 0 0 120px rgba(0,0,0,.5);overflow:hidden}
#game-frame::after{content:'';position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse at center,transparent 60%,rgba(0,0,0,.4) 100%);z-index:4}
canvas#game{display:block;width:100%;height:100%;background:linear-gradient(to bottom,#0a0f1f 0%,#1a0a2e 55%,#2b0d3a 100%)}
#hud{position:absolute;inset:0;pointer-events:none;z-index:5;padding:14px 18px;display:grid;grid-template-columns:1fr auto 1fr;grid-template-rows:auto 1fr auto;gap:8px;font-family:var(--fM)}
.hc{background:linear-gradient(180deg,rgba(10,15,31,.85),rgba(10,15,31,.55));border:1px solid rgba(0,240,255,.3);padding:6px 10px;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);clip-path:polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,8px 100%,0 calc(100% - 8px))}
.hc.r{clip-path:polygon(8px 0,100% 0,100% calc(100% - 8px),calc(100% - 8px) 100%,0 100%,0 8px)}
.hl{font-size:9px;letter-spacing:.18em;color:var(--cy);text-transform:uppercase;opacity:.85}
.hv{font-family:var(--fD);font-weight:700;font-size:16px;color:var(--t0);text-shadow:var(--gC);line-height:1;margin-top:2px}
.hv.m{color:var(--mg);text-shadow:var(--gM)}.hv.y{color:var(--yl);text-shadow:var(--gY)}.hv.g{color:var(--gn);text-shadow:var(--gG)}.hv.v{color:var(--vt);text-shadow:var(--gV)}.hv.o{color:var(--or)}
#hud-tl{grid-column:1;grid-row:1;display:flex;gap:6px;align-items:flex-start;flex-wrap:wrap}
#hud-tc{grid-column:2;grid-row:1;text-align:center}
#hud-tr{grid-column:3;grid-row:1;display:flex;gap:6px;justify-content:flex-end;align-items:flex-start;flex-wrap:wrap}
.pb{height:5px;width:110px;background:rgba(255,255,255,.08);border:1px solid rgba(255,43,214,.3);overflow:hidden;margin-top:3px}
.pbf{height:100%;background:linear-gradient(90deg,var(--mg),var(--vt));box-shadow:0 0 6px var(--mg);transition:width .25s}
.pbf.h{background:linear-gradient(90deg,var(--yl),var(--or),var(--rd));box-shadow:0 0 6px var(--or)}
#faction-bar{position:absolute;top:52px;left:14px;background:rgba(10,15,31,.75);border:1px solid rgba(0,240,255,.2);padding:6px 10px;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);font-family:var(--fM);font-size:10px;z-index:5;display:none}
#faction-bar.show{display:block}
.fr-t{color:var(--cy);font-size:9px;letter-spacing:.2em;text-transform:uppercase;margin-bottom:6px}
.fr{display:flex;align-items:center;gap:6px;padding:2px 0}
.fd{width:7px;height:7px;border-radius:50%}
.fn{color:var(--t1);width:60px;font-size:9px}
.rb{width:48px;height:4px;background:rgba(255,255,255,.08);position:relative}
.rbf{height:100%}
.rb0{position:absolute;left:50%;top:-1px;width:1px;height:6px;background:var(--t3)}
#combo{position:absolute;top:50%;right:24px;transform:translateY(-50%);font-family:var(--fD);font-weight:900;font-size:54px;color:var(--yl);text-shadow:var(--gY);opacity:0;transition:opacity .3s;pointer-events:none;z-index:6}
#combo.on{opacity:1}
#combo.huge{font-size:84px;color:var(--mg);text-shadow:var(--gM);animation:ch .6s ease}
@keyframes ch{0%,100%{transform:translateY(-50%) scale(1)}50%{transform:translateY(-50%) scale(1.2)}}
