const cv=document.getElementById('game'),ctx=cv.getContext('2d');
let W=0,H=0;
function resize(){const r=cv.getBoundingClientRect(),dpr=Math.min(window.devicePixelRatio||1,2);cv.width=r.width*dpr;cv.height=r.height*dpr;ctx.setTransform(dpr,0,0,dpr,0,0);W=r.width;H=r.height}
window.addEventListener('resize',resize);

const G={
  st:'menu',md:'free',sCh:null,
  lns:[0.25,0.5,0.75],
  car:{ln:1,x:0,y:0,tx:0,w:36,h:56,lives:3,inv:0,bst:0},
  speed:4,bSp:4,mSp:16,
  distance:0,score:0,leads:0,leadsTotal:0,dataS:0,
  credits:S.g('credits',0),
  combo:1,bestCombo:1,coT:0,mult:1,mT:0,
  heat:0,hotZ:false,
  obs:[],pks:[],pts:[],rain:[],
  mods:mOwn,
  chk:1,chCorrect:0,bstCount:0,
  lstO:0,lstP:0,
  pCRM:false,frSolv:false,scrY:0,
  weather:'clear',skipCh:false,beats:{},vendT:false,
  ai:{cr:0,pk:0,la:0,d:0.5},usedR:false
};

function spawnO(){let ln=rngI(0,2);let ty=rng()<(0.6+G.ai.d*0.2)?'block':'spike';G.obs.push({ty,ln,x:G.lns[ln]*W,y:-60,w:50,h:60});if(G.hotZ&&rng()<0.4){let l2=(ln+1+rngI(0,1))%3;G.obs.push({ty:'block',ln:l2,x:G.lns[l2]*W,y:-100,w:50,h:60})}}

function spawnP(){const ln=rngI(0,2),r=rng();let ty;const dc=(G.weather==='rain'?0.18:0.05)*(hasM('analytics')?2:1);if(r<dc)ty='data';else if(r<0.65)ty='lead';else if(r<0.85)ty='energy';else ty='boost';G.pks.push({ty,ln,x:G.lns[ln]*W,y:-30,w:26,h:26,t:0})}

function spawnPart(x,y,col,n=8){for(let i=0;i<n;i++)G.pts.push({x,y,vx:(Math.random()-.5)*6,vy:(Math.random()-.5)*6-2,life:1,col,sz:2+Math.random()*3})}

function spawnRain(){if(G.weather!=='rain')return;if(G.rain.length<60)G.rain.push({x:Math.random()*W,y:-10,sp:8+Math.random()*4})}

function aiDir(dt){G.ai.la+=dt;if(G.ai.la<5)return;G.ai.la=0;if(G.ai.cr>=2)G.ai.d=Math.max(0,G.ai.d-0.15);else if(G.ai.pk>30)G.ai.d=Math.min(1,G.ai.d+0.1);G.ai.cr=0;G.ai.pk=0}

let shX=0,shY=0,shT=0,shI=0;
function shake(i,d){shI=i;shT=d}

function update(dt){
  if(G.st!=='running')return;
  G.speed=Math.min(G.mSp,G.bSp+G.distance/500);
  if(G.car.bst>0){G.speed*=1.7;G.car.bst-=dt}
  if(G.hotZ)G.speed*=1.15;
  G.distance+=G.speed*dt*6;G.scrY+=G.speed*dt*60;
  G.heat=Math.min(100,G.heat+(G.car.inv>0?0:dt*4+G.combo*0.2));
  if(G.heat>=100&&!G.hotZ){G.hotZ=true;toast('🔥 '+t('t_hot'),'r');A.b(220,.3,'sawtooth',1);unlock('hz')}
  else if(G.heat<60&&G.hotZ)G.hotZ=false;
  document.getElementById('h-hf').style.width=G.heat+'%';document.getElementById('h-h').textContent=Math.floor(G.heat);
  let sg=G.speed*dt*6*G.mult;
  if(G.weather==='fog')sg*=1.5;
  if(G.hotZ)sg*=2;
  if(hasN('mb'))sg*=1.5;
  if(hasM('nexus'))sg*=1.25;
  G.score+=Math.floor(sg);
  G.car.tx=G.lns[G.car.ln]*W;G.car.x+=(G.car.tx-G.car.x)*0.18;G.car.y=H-110;
  if(G.car.inv>0)G.car.inv-=dt;
  if(G.coT>0){G.coT-=dt;if(G.coT<=0)G.combo=1}
  if(G.mT>0){G.mT-=dt;if(G.mT<=0)G.mult=1}
  aiDir(dt);
  G.lstO+=dt;G.lstP+=dt;
  const obR=Math.max(0.5,1.4-G.distance/8000)*(1-G.ai.d*0.3);
  if(G.lstO>obR){spawnO();G.lstO=0}
  if(G.lstP>0.7){spawnP();G.lstP=0}
  if(G.weather==='rain')spawnRain();
  const mv=G.speed*60;
  G.obs.forEach(o=>o.y+=mv*dt);G.obs=G.obs.filter(o=>o.y<H+80);
  const mag=hasM('booking')||hasM('inbound');
  G.pks.forEach(p=>{p.y+=mv*dt;p.t+=dt;if(mag&&(p.ty==='lead'||(hasM('inbound')&&p.ty!=='data'))){const d=Math.abs(p.y-G.car.y);if(d<200)p.x+=(G.car.x-p.x)*0.06}});
  G.pks=G.pks.filter(p=>p.y<H+30);
  G.rain.forEach(r=>r.y+=r.sp);G.rain=G.rain.filter(r=>r.y<H+10);
  G.pts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.vy+=0.2;p.life-=dt*1.5});G.pts=G.pts.filter(p=>p.life>0);
  const cx=G.car.x,cy=G.car.y,cw=G.car.w,ch=G.car.h;
  G.obs.forEach((o,i)=>{if(Math.abs(o.x-cx)<(cw+o.w)/2-8&&Math.abs(o.y-cy)<(ch+o.h)/2-8){if(G.car.inv<=0){hitO();G.obs.splice(i,1)}}});
  G.pks.forEach((p,i)=>{if(Math.abs(p.x-cx)<(cw+p.w)/2&&Math.abs(p.y-cy)<(ch+p.h)/2){collP(p);G.pks.splice(i,1)}});
  if(G.distance>=G.chk*1000){G.chk++;if(G.skipCh){G.skipCh=false;toast(t('t_skip'),'v')}else trigCode()}
  const bk=Math.floor(G.distance/700);
  if(bk>0&&!G.beats[bk]&&G.md!=='story'&&rng()<0.4){G.beats[bk]=true;trigBeat()}
  if(G.distance>=1500&&!G.vendT&&rng()<0.6){G.vendT=true;trigVend()}
  if(G.leadsTotal>0&&G.leadsTotal%10===0&&!G.pCRM&&G.leads>=10){G.pCRM=true;G.leads=0;setTimeout(openCRM,200)}
  if(G.distance>=1000)unlock('km1');
  if(G.distance>=5000)unlock('km5');
  if(G.distance>=10000)unlock('km10');
  if(G.combo>=5)unlock('co5');if(G.combo>=10)unlock('co10');if(G.combo>=20)unlock('co20');
  if(G.leadsTotal>=10)unlock('lds10');if(G.leadsTotal>=50)unlock('lds50');
  if(G.chCorrect>=3)unlock('hk3');
  ['acq','ret','ops','intel'].forEach(tr=>{if(MODS.filter(m=>m.tr===tr).every(m=>hasM(m.id)))unlock(tr)});
  if(MODS.every(m=>hasM(m.id)))unlock('all');
  if(G.md==='story'&&G.sCh)chkCh();
  upHUD();
}

function hitO(){A.crash();G.car.inv=1.5;spawnPart(G.car.x,G.car.y,'#ff3b6b',20);shake(10,0.4);G.heat=Math.max(0,G.heat-30);G.ai.cr++;let l=1;if(hasM('autosave')&&rng()<0.5)l=0;G.car.lives-=l;if(!hasM('churn')){G.combo=1;G.coT=0}toast(t('t_crash'),'m');if(G.car.lives<=0){if(hasN('2c')&&!G.usedR){G.usedR=true;G.car.lives=2;G.car.inv=3;toast('⚛ SECOND CHANCE','v');A.mod()}else gameOver()}}

function collP(p){G.ai.pk++;spawnPart(p.x,p.y,p.ty==='lead'?'#ff2bd6':p.ty==='energy'?'#00f0ff':p.ty==='data'?'#8a3bff':'#ffe600',12);
  if(p.ty==='lead'){G.leads++;G.leadsTotal++;G.combo++;if(G.combo>G.bestCombo)G.bestCombo=G.combo;G.coT=3;if(hasM('pipeline'))G.combo++;
    let cb=50*G.mult*G.combo;if(hasM('kanban'))cb*=1.1;if(hasM('billing'))cb*=1.25;if(hasM('lead_ai'))cb*=1.5;if(hasM('nexus'))cb*=1.25;if(G.hotZ)cb*=2;
    G.credits+=Math.floor(cb);G.score+=Math.floor(100*G.mult*G.combo);
    if(hasM('rbac'))G.car.inv=Math.max(G.car.inv,0.5);
    A.lead();upCombo()}
  else if(p.ty==='energy'){G.score+=200*G.mult;if(hasM('flow')){G.leads++;G.leadsTotal++}A.en2()}
  else if(p.ty==='data'){let am=1;if(hasN('db'))am*=2;G.dataS+=am;tData+=am;S.s('tData',tData);A.dat();toast('💎 +'+am,'v');if(tData>=50)unlock('d50');if(tData>=500)unlock('d500')}
  else{let d=5;if(hasM('quantum'))d*=2;if(G.weather==='flare')d*=1.5;G.car.bst=d;G.bstCount++;toast(t('t_boost'),'c');A.b(880,.2,'sawtooth',.8);if(G.bstCount>=5)unlock('spd')}}

function upCombo(){const el=document.getElementById('combo');if(G.combo>1){document.getElementById('combo-n').textContent=G.combo;el.classList.add('on');el.classList.toggle('huge',G.combo>=10);clearTimeout(window._ct);window._ct=setTimeout(()=>el.classList.remove('on','huge'),800)}}

function render(){
  ctx.save();
  if(shT>0){shX=(Math.random()-.5)*shI;shY=(Math.random()-.5)*shI;shT-=1/60;ctx.translate(shX,shY)}
  ctx.fillStyle='#0a0f1f';ctx.fillRect(0,0,W,H);
  const grd=ctx.createLinearGradient(0,0,0,H*0.6);
  if(G.hotZ){grd.addColorStop(0,'rgba(40,15,15,1)');grd.addColorStop(0.7,'rgba(255,59,107,0.25)');grd.addColorStop(1,'rgba(255,140,26,0.35)')}
  else{grd.addColorStop(0,'rgba(10,15,31,1)');grd.addColorStop(0.7,'rgba(138,59,255,0.18)');grd.addColorStop(1,'rgba(255,43,214,0.25)')}
  ctx.fillStyle=grd;ctx.fillRect(0,0,W,H*0.6);
  ctx.save();
  const sY=H*0.45,sR=Math.min(W,H)*0.12;
  const sG=ctx.createRadialGradient(W/2,sY,0,W/2,sY,sR);
  if(G.hotZ){sG.addColorStop(0,'rgba(255,140,26,.95)');sG.addColorStop(0.4,'rgba(255,59,107,.55)')}
  else{sG.addColorStop(0,'rgba(255,230,0,.9)');sG.addColorStop(0.4,'rgba(255,43,214,.5)')}
  sG.addColorStop(1,'rgba(138,59,255,0)');
  ctx.fillStyle=sG;ctx.beginPath();ctx.arc(W/2,sY,sR*2,0,Math.PI*2);ctx.fill();
  for(let i=0;i<5;i++){ctx.fillStyle='rgba(10,15,31,1)';ctx.fillRect(W/2-sR,sY-sR+i*sR*0.5,sR*2,3)}
  ctx.restore();
  const hY=H*0.5;
  ctx.strokeStyle=G.hotZ?'rgba(255,140,26,.3)':'rgba(0,240,255,.25)';ctx.lineWidth=1;
  const gs=(G.scrY*0.3)%50;
  ctx.beginPath();ctx.moveTo(0,hY);ctx.lineTo(W,hY);ctx.stroke();
  for(let i=1;i<=10;i++){const z=i+(gs/50),y=hY+((H-hY)*(z*z/100));if(y>H)continue;const al=1-(z/10);ctx.strokeStyle=G.hotZ?`rgba(255,140,26,${0.4*al})`:`rgba(0,240,255,${0.4*al})`;ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke()}
  ctx.strokeStyle=G.hotZ?'rgba(255,59,107,.4)':'rgba(255,43,214,.3)';
  for(let i=-8;i<=8;i++){if(i===0)continue;ctx.beginPath();ctx.moveTo(W/2,hY);ctx.lineTo(W/2+i*W*0.13,H);ctx.stroke()}
  ctx.fillStyle='rgba(10,5,20,.85)';
  ctx.beginPath();ctx.moveTo(W*0.15,H);ctx.lineTo(W*0.4,hY);ctx.lineTo(W*0.6,hY);ctx.lineTo(W*0.85,H);ctx.closePath();ctx.fill();
  ctx.save();ctx.strokeStyle=G.hotZ?'rgba(255,140,26,.8)':'rgba(0,240,255,.7)';ctx.lineWidth=2;ctx.shadowColor=G.hotZ?'#ff8c1a':'#00f0ff';ctx.shadowBlur=10;
  for(let ln=1;ln<=2;ln++){const tx=W*0.4+(W*0.2)*(ln/3),bx=W*0.15+(W*0.7)*(ln/3),of=(G.scrY*1.5)%60;
    for(let i=0;i<12;i++){const ts=(i/12)+(of/600),te=ts+0.04;if(te>1)continue;const x1=tx+(bx-tx)*ts,y1=hY+(H-hY)*ts,x2=tx+(bx-tx)*te,y2=hY+(H-hY)*te;ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke()}}
  ctx.restore();
  ctx.save();ctx.strokeStyle=G.hotZ?'#ff3b6b':'#ff2bd6';ctx.shadowColor=G.hotZ?'#ff3b6b':'#ff2bd6';ctx.shadowBlur=14;ctx.lineWidth=3;
  ctx.beginPath();ctx.moveTo(W*0.4,hY);ctx.lineTo(W*0.15,H);ctx.moveTo(W*0.6,hY);ctx.lineTo(W*0.85,H);ctx.stroke();ctx.restore();
  if(G.weather==='rain'){ctx.strokeStyle='rgba(0,240,255,.4)';ctx.lineWidth=1;G.rain.forEach(r=>{ctx.beginPath();ctx.moveTo(r.x,r.y);ctx.lineTo(r.x-2,r.y+12);ctx.stroke()})}
  if(G.weather==='fog'){ctx.fillStyle='rgba(180,180,210,.4)';ctx.fillRect(0,0,W,H)}
  // Obstacles
  G.obs.forEach(o=>{ctx.save();if(o.ty==='block'){ctx.fillStyle='rgba(255,59,107,.85)';ctx.shadowColor='#ff3b6b';ctx.shadowBlur=18;ctx.fillRect(o.x-o.w/2,o.y-o.h/2,o.w,o.h);ctx.strokeStyle='#ff3b6b';ctx.lineWidth=2;ctx.strokeRect(o.x-o.w/2,o.y-o.h/2,o.w,o.h);ctx.fillStyle='rgba(255,255,255,.15)';for(let y=-o.h/2;y<o.h/2;y+=5)ctx.fillRect(o.x-o.w/2,o.y+y,o.w,2)}
    else{ctx.fillStyle='rgba(255,230,0,.9)';ctx.shadowColor='#ffe600';ctx.shadowBlur=18;ctx.beginPath();ctx.moveTo(o.x,o.y-o.h/2);ctx.lineTo(o.x+o.w/2,o.y+o.h/2);ctx.lineTo(o.x-o.w/2,o.y+o.h/2);ctx.closePath();ctx.fill();ctx.strokeStyle='#ff2bd6';ctx.lineWidth=2;ctx.stroke()}ctx.restore()});
  // Pickups
  G.pks.forEach(p=>{ctx.save();const pu=Math.sin(p.t*8)*0.2+0.8;
    if(p.ty==='lead'){ctx.fillStyle='#ff2bd6';ctx.shadowColor='#ff2bd6';ctx.shadowBlur=20*pu;ctx.beginPath();ctx.arc(p.x,p.y,p.w/2*pu,0,Math.PI*2);ctx.fill();ctx.fillStyle='#fff';ctx.font='bold 14px monospace';ctx.textAlign='center';ctx.textBaseline='middle';ctx.shadowBlur=0;ctx.fillText('$',p.x,p.y)}
    else if(p.ty==='energy'){ctx.fillStyle='#00f0ff';ctx.shadowColor='#00f0ff';ctx.shadowBlur=18*pu;ctx.beginPath();ctx.moveTo(p.x,p.y-p.h/2);ctx.lineTo(p.x+p.w/2,p.y);ctx.lineTo(p.x,p.y+p.h/2);ctx.lineTo(p.x-p.w/2,p.y);ctx.closePath();ctx.fill()}
    else if(p.ty==='data'){ctx.fillStyle='#8a3bff';ctx.shadowColor='#8a3bff';ctx.shadowBlur=22*pu;ctx.beginPath();for(let i=0;i<6;i++){const a=(i/6)*Math.PI*2+p.t*2,px=p.x+Math.cos(a)*p.w/2*pu,py=p.y+Math.sin(a)*p.h/2*pu;if(i===0)ctx.moveTo(px,py);else ctx.lineTo(px,py)}ctx.closePath();ctx.fill()}
    else{ctx.fillStyle='#ffe600';ctx.shadowColor='#ffe600';ctx.shadowBlur=22*pu;ctx.beginPath();ctx.moveTo(p.x-4,p.y-p.h/2);ctx.lineTo(p.x+8,p.y-4);ctx.lineTo(p.x+2,p.y-2);ctx.lineTo(p.x+8,p.y+p.h/2);ctx.lineTo(p.x-6,p.y+4);ctx.lineTo(p.x,p.y+2);ctx.closePath();ctx.fill()}
    ctx.restore()});
  // Car
  ctx.save();
  const x=G.car.x,y=G.car.y,cw=G.car.w,ch=G.car.h;
  if(G.car.inv>0&&Math.floor(G.car.inv*10)%2)ctx.globalAlpha=0.4;
  if(G.car.bst>0){for(let i=0;i<6;i++){ctx.save();ctx.globalAlpha=0.3-i*0.04;ctx.fillStyle='#ffe600';ctx.shadowColor='#ffe600';ctx.shadowBlur=20;ctx.fillRect(x-cw/2+4,y+ch/2+i*8,cw-8,6);ctx.restore()}}
  ctx.fillStyle='rgba(0,0,0,.4)';ctx.beginPath();ctx.ellipse(x,y+ch/2+6,cw*0.55,4,0,0,Math.PI*2);ctx.fill();
  ctx.shadowColor=G.hotZ?'#ff8c1a':'#00f0ff';ctx.shadowBlur=24;
  const gr=ctx.createLinearGradient(x-cw/2,y,x+cw/2,y);gr.addColorStop(0,'#0a0f1f');gr.addColorStop(0.5,'#1a2456');gr.addColorStop(1,'#0a0f1f');
  ctx.fillStyle=gr;ctx.beginPath();ctx.moveTo(x,y-ch/2);ctx.lineTo(x+cw/2,y-ch/4);ctx.lineTo(x+cw/2-4,y+ch/2);ctx.lineTo(x-cw/2+4,y+ch/2);ctx.lineTo(x-cw/2,y-ch/4);ctx.closePath();ctx.fill();
  ctx.strokeStyle=G.hotZ?'#ff8c1a':'#00f0ff';ctx.lineWidth=1.5;ctx.stroke();
  ctx.fillStyle='rgba(255,43,214,.35)';ctx.shadowBlur=8;ctx.beginPath();ctx.moveTo(x-cw/3,y-ch/6);ctx.lineTo(x+cw/3,y-ch/6);ctx.lineTo(x+cw/4,y+ch/8);ctx.lineTo(x-cw/4,y+ch/8);ctx.closePath();ctx.fill();
  ctx.shadowBlur=16;ctx.fillStyle='#fff';ctx.fillRect(x-cw/2+4,y-ch/2+4,6,4);ctx.fillRect(x+cw/2-10,y-ch/2+4,6,4);
  ctx.shadowColor='#ff3b6b';ctx.fillStyle='#ff3b6b';ctx.fillRect(x-cw/2+4,y+ch/2-6,cw-8,3);
  ctx.restore();
  // Particles
  G.pts.forEach(p=>{ctx.save();ctx.globalAlpha=Math.max(0,p.life);ctx.fillStyle=p.col;ctx.shadowColor=p.col;ctx.shadowBlur=10;ctx.beginPath();ctx.arc(p.x,p.y,p.sz,0,Math.PI*2);ctx.fill();ctx.restore()});
  // Lives
  ctx.save();for(let i=0;i<G.car.lives;i++){ctx.fillStyle='#ff2bd6';ctx.shadowColor='#ff2bd6';ctx.shadowBlur=8;ctx.beginPath();ctx.arc(20+i*22,H-24,7,0,Math.PI*2);ctx.fill()}ctx.restore();
  // Weather label
  if(G.weather!=='clear'){ctx.save();ctx.font='10px JetBrains Mono';ctx.textAlign='right';const w=WTHR.find(x=>x.id===G.weather);if(w){ctx.fillStyle='rgba(170,179,217,.6)';ctx.fillText('☁ '+w['n_'+LANG],W-20,H-16)}ctx.restore()}
  ctx.restore();
}

function upHUD(){
  document.getElementById('h-d').textContent=Math.floor(G.distance)+'M';
  document.getElementById('h-s').textContent=Math.floor(G.speed*20);
  document.getElementById('h-sc').textContent=G.score.toLocaleString();
  document.getElementById('h-l').textContent=G.leadsTotal;
  document.getElementById('h-c').textContent=Math.floor(G.credits);
  document.getElementById('h-da').textContent=G.dataS;
  document.getElementById('h-lf').style.width=((G.leads%10)*10)+'%';
}

let lastT=0;
function loop(t){const dt=Math.min(0.05,(t-lastT)/1000);lastT=t;update(dt);render();requestAnimationFrame(loop)}

/* ---- Flow ---- */
function startG(md='free'){A.init();hideAll();G.st='running';G.md=md;
  G.distance=0;G.score=0;G.leads=0;G.leadsTotal=0;G.dataS=0;
  G.combo=1;G.bestCombo=1;G.coT=0;G.mult=hasN('mb')?1.5:1;G.mT=0;
  G.heat=0;G.hotZ=false;G.obs=[];G.pks=[];G.pts=[];G.rain=[];
  G.chk=1;G.chCorrect=0;G.bstCount=0;
  G.car.lives=hasN('sl')?4:3;G.car.ln=1;G.car.inv=0;G.car.bst=0;
  G.pCRM=false;G.frSolv=hasM('ai_co');G.weather=WTHR[rngI(0,WTHR.length-1)].id;
  G.skipCh=false;G.beats={};G.vendT=false;G.usedR=false;
  G.ai={cr:0,pk:0,la:0,d:0.5};
  if(hasN('sc'))G.credits+=500;
  runs++;S.s('runs',runs);
  if(md==='daily'){setSeed(getDaily().seed)}else setSeed(Date.now()%233280);
  resize();upHUD();chkStreak();showObj();
  if(G.weather!=='clear'){const w=WTHR.find(x=>x.id===G.weather);setTimeout(()=>toast('☁ '+w['n_'+LANG],'c'),400)}
}

function showObj(){const ol=document.getElementById('obj-list');let html='';
  if(G.md==='story'&&G.sCh){const c=CHAP.find(x=>x.id===G.sCh);if(c)html=`<div class="oi">▸ ${LANG==='ro'?'Atinge':'Reach'} ${c.d}m</div>`}
  else if(G.md==='daily'){const d=getDaily();html=`<div class="oi">▸ ${LANG==='ro'?d.r:d.e} (+${d.rw} CR)</div>`}
  else html=`<div class="oi">▸ ${LANG==='ro'?'Run liber':'Free run'}</div>`;
  ol.innerHTML=html;document.getElementById('obj').classList.add('on')}

function pauseG(){if(G.st!=='running')return;G.st='paused';document.getElementById('p-d').textContent=Math.floor(G.distance)+'M';document.getElementById('p-s').textContent=G.score.toLocaleString();document.getElementById('p-c').textContent='×'+G.combo;show('ov-pause')}
function resumeG(){if(G.st!=='paused')return;hideAll();G.st='running'}

function openCRM(){G.st='crm';document.getElementById('cr-c').textContent=Math.floor(G.credits);document.getElementById('cr-l').textContent=G.leadsTotal;document.getElementById('cr-m').textContent=Object.keys(G.mods).length+'/16';renderM();show('ov-crm')}

function renderM(){
  ['acq','ret','ops','intel'].forEach(tr=>{const el=document.getElementById('tr-'+tr);el.innerHTML='';
    MODS.filter(m=>m.tr===tr).forEach(m=>{
      const ow=!!G.mods[m.id];
      let cost=m.c;if(hasN('ua')&&m.t===1)cost=0;
      const af=G.credits>=cost;
      const tu=m.t===1||MODS.filter(o=>o.tr===tr&&o.t<m.t).every(o=>!!G.mods[o.id]);
      const lk=!tu;
      const d=document.createElement('div');d.className='md'+(ow?' ow':(lk||!af?' lk':''));
      d.innerHTML=`<div class="mdt">T${m.t}</div><div class="mdn">${m.n}</div><div class="mdd">${m['d_'+LANG]}</div><div class="mdc">${cost} CR</div>`;
      if(!ow&&!lk&&af){d.addEventListener('click',()=>{G.credits-=cost;G.mods[m.id]=true;mOwn=G.mods;S.s('mods',G.mods);A.mod();gainXP(50);toast(t('t_mod')+' · '+m.n,'c');renderM();document.getElementById('cr-c').textContent=Math.floor(G.credits);document.getElementById('cr-m').textContent=Object.keys(G.mods).length+'/16'})}
      el.appendChild(d)})});
}

function contCRM(){hideAll();G.st='running';G.pCRM=false}

function trigCode(){
  G.st='code';
  const c=CH[Math.floor(rng()*CH.length)];
  document.getElementById('c-cat').textContent=c.cat;
  document.getElementById('c-q').textContent=c.q;
  document.getElementById('c-b').innerHTML=c.code;
  const ae=document.getElementById('c-a');ae.innerHTML='';
  const idx=c.a.map((_,i)=>i);
  for(let i=idx.length-1;i>0;i--){const j=Math.floor(rng()*(i+1));[idx[i],idx[j]]=[idx[j],idx[i]]}
  let resolved=false;
  idx.forEach(o=>{const b=document.createElement('button');b.className='ab';b.textContent=c.a[o];b.addEventListener('click',()=>{if(resolved)return;resolved=true;clearInterval(tI);handleAns(o===c.c,b,idx,c.c)});ae.appendChild(b)});
  if(G.frSolv){G.frSolv=false;setTimeout(()=>{if(resolved)return;resolved=true;clearInterval(tI);const cb=Array.from(ae.children)[idx.indexOf(c.c)];toast('🤖 AI COPILOT','c');handleAns(true,cb,idx,c.c)},1500)}
  let tl=8;const tf=document.getElementById('c-t');tf.style.width='100%';
  const tI=setInterval(()=>{tl-=0.1;tf.style.width=(tl/8*100)+'%';if(tl<=0&&!resolved){resolved=true;clearInterval(tI);handleAns(false,null,idx,c.c)}},100);
  show('ov-code');
}

function handleAns(ok,btn,idx,ci){
  const ae=document.getElementById('c-a');
  Array.from(ae.children).forEach((b,i)=>{b.style.pointerEvents='none';if(idx[i]===ci)b.classList.add('cr')});
  if(btn&&!ok)btn.classList.add('wr');
  setTimeout(()=>{hideAll();G.st='running';
    if(ok){G.mult=2;G.mT=15;G.credits+=300;G.score+=500;G.dataS+=50;G.chCorrect++;chRep('null',3);gainXP(30);
      const tc=S.g('tCorrect',0)+1;S.s('tCorrect',tc);if(tc>=10)unlock('hk10');
      toast(t('t_correct'),'y');A.ok()}
    else{G.speed=Math.max(2,G.speed*0.5);G.bSp=Math.max(2,G.bSp*0.85);G.heat=Math.min(100,G.heat+20);setTimeout(()=>{G.bSp=4},3000);toast(t('t_wrong'),'m');A.no()}},1200);
}

function trigBeat(){const fIds=Object.keys(BEATS),fId=fIds[Math.floor(rng()*fIds.length)];const bs=BEATS[fId],b=bs[Math.floor(rng()*bs.length)];
  document.getElementById('sd-sp').textContent='— '+b.s;document.getElementById('sd-tx').textContent=b['tx_'+LANG];
  const ce=document.getElementById('sd-ch');ce.innerHTML='';
  b.ch.forEach(c=>{const btn=document.createElement('button');btn.className='sch';btn.textContent=LANG==='ro'?c.tr:c.te;
    btn.addEventListener('click',()=>{applyEff(c.e);hideSD()});ce.appendChild(btn)});
  document.getElementById('story-d').classList.add('on');A.dlg();
  setTimeout(()=>{if(document.getElementById('story-d').classList.contains('on'))hideSD()},12000)}

function hideSD(){document.getElementById('story-d').classList.remove('on')}

function applyEff(e){if(e.f&&e.dl)chRep(e.f,e.dl);if(e.f2&&e.dl2)chRep(e.f2,e.dl2);if(e.dat)G.dataS=Math.max(0,G.dataS+e.dat);if(e.cr)G.credits=Math.max(0,G.credits+e.cr);if(e.lf)G.car.lives+=e.lf;if(e.bst)G.car.bst+=e.bst;if(e.sk)G.skipCh=true;toast(e['m_'+LANG],'v')}

function trigVend(){G.st='vendor';const f=FACS[Math.floor(rng()*FACS.length)],r=fRep[f.id]||0,al=r>=50;
  document.getElementById('v-lbl').textContent='// VENDOR · '+f.n+' · REP '+r;
  const vt=document.getElementById('v-t');vt.textContent=f.n;vt.style.color=f.hex;
  document.getElementById('v-g').textContent=al?(LANG==='ro'?'Aliat! Prețuri reduse.':'Ally! Discounted.'):(r>=0?(LANG==='ro'?'Neutru.':'Neutral.'):(LANG==='ro'?'Ostil. Prețuri umflate.':'Hostile. Inflated.'));
  const its=[{n_ro:'Boost instant',n_en:'Instant boost',c:300,e:()=>G.car.bst+=5},
    {n_ro:'Refill viață',n_en:'Refill life',c:500,e:()=>G.car.lives=Math.min(5,G.car.lives+1)},
    {n_ro:'Combo seed ×3',n_en:'Combo seed ×3',c:400,e:()=>{G.combo=Math.max(G.combo,3);G.coT=10}},
    {n_ro:'Reset Heat',n_en:'Reset Heat',c:200,e:()=>{G.heat=0;G.hotZ=false}}];
  const mul=al?0.7:(r<0?1.4:1);
  const ie=document.getElementById('v-it');ie.innerHTML='';
  its.forEach(it=>{const cost=Math.floor(it.c*mul),af=G.credits>=cost;
    const d=document.createElement('div');d.className='md'+(!af?' lk':'');
    d.innerHTML=`<div class="mdn">${it['n_'+LANG]}</div><div class="mdc">${cost} CR</div>`;
    if(af)d.addEventListener('click',()=>{G.credits-=cost;it.e();A.mod();toast('✓ '+it['n_'+LANG],'c');leaveV()});
    ie.appendChild(d)});
  show('ov-vend');toast('🛒 '+t('t_vendor'),'c')}

function leaveV(){hideAll();G.st='running'}

function chkCh(){const c=CHAP.find(x=>x.id===G.sCh);if(!c)return;if(G.distance>=c.d&&!sProg[c.id]){sProg[c.id]=true;S.s('sProg',sProg);toast('📖 '+t('t_ch')+' '+c.id,'v');G.credits+=1000;gainXP(150);if(c.id>=3)unlock('ch3');if(Object.keys(sProg).length>=12)unlock('cha')}}

function gameOver(){
  G.st='gameover';document.getElementById('obj').classList.remove('on');
  const d=getDaily(),td=new Date().toDateString(),ld=S.g('lastDaily',null);
  if(ld!==td&&d.c(G)){G.credits+=d.rw;S.s('lastDaily',td);unlock('ds');toast('🎲 DAILY +'+d.rw+' CR','y')}
  const xg=Math.floor(G.score/100);gainXP(xg);S.s('credits',G.credits);
  const lb=S.g('lb',[]);lb.push({score:G.score,distance:Math.floor(G.distance),leads:G.leadsTotal,credits:Math.floor(G.credits),data:G.dataS,mode:G.md,date:new Date().toISOString()});
  lb.sort((a,b)=>b.score-a.score);S.s('lb',lb.slice(0,20));
  document.getElementById('e-d').textContent=Math.floor(G.distance)+'M';
  document.getElementById('e-s').textContent=G.score.toLocaleString();
  document.getElementById('e-l').textContent=G.leadsTotal;
  document.getElementById('e-c').textContent=Math.floor(G.credits);
  document.getElementById('e-ch').textContent=G.chCorrect;
  document.getElementById('e-m').textContent=Object.keys(G.mods).length;
  document.getElementById('e-da').textContent=G.dataS;
  document.getElementById('e-x').textContent='+'+xg;
  renderLB('e-lb',G.score);show('ov-end');
}

function renderLB(id,hs){const lb=S.g('lb',[]),el=document.getElementById(id);
  if(lb.length===0){el.innerHTML='<div class="lbr"><span style="grid-column:1/-1;color:var(--t2);text-align:center">— '+(LANG==='ro'?'Niciun run salvat':'No runs yet')+' —</span></div>';return}
  el.innerHTML=lb.slice(0,10).map((r,i)=>{const y=r.score===hs&&i<5;let rc='';if(i===0)rc='g';else if(i===1)rc='s2';else if(i===2)rc='br';
    return `<div class="lbr ${y?'you':''}"><span class="lr ${rc}">#${i+1}</span><span class="ln">${y?(LANG==='ro'?'TU':'YOU'):'AGENT-'+Math.floor(rng()*900+100)}</span><span class="ls">${r.score.toLocaleString()}</span><span style="color:var(--t2)">${r.distance}M</span><span style="color:var(--vt)">${r.mode||'free'}</span></div>`}).join('')}

function updateFacBar(){const el=document.getElementById('fr-rows');
  el.innerHTML=FACS.map(f=>{const r=fRep[f.id]||0,po=r>=0,fc=po?f.hex:'#ff3b6b',off=po?50:(50-Math.abs(r)/2);
    return `<div class="fr"><div class="fd" style="background:${f.hex}"></div><span class="fn">${f.n.split('·')[0]}</span><div class="rb"><div class="rb0"></div><div class="rbf" style="background:${fc};width:${Math.abs(r)/2}%;margin-left:${off}%"></div></div><span style="color:${fc};font-size:9px;min-width:22px;text-align:right">${r>0?'+':''}${r}</span></div>`}).join('')}

function renderFC(){const el=document.getElementById('f-cards');
  el.innerHTML=FACS.map(f=>{const r=fRep[f.id]||0,fc=r>=0?f.hex:'#ff3b6b';
    return `<div class="fc" style="border-left-color:${f.hex}"><div class="fci"><h4 style="color:${f.hex}">${f.n}</h4><p>${f['d_'+LANG]}</p></div><div class="frn" style="color:${fc}">${r>0?'+':''}${r}</div></div>`}).join('')}

function renderACH(){const g=document.getElementById('a-grid'),uc=Object.keys(unl).length;
  document.getElementById('a-prog').textContent=uc+' / '+ACHS.length;
  g.innerHTML=ACHS.map(a=>{const u=!!unl[a.id];return `<div class="a ${u?'u':''}"><div class="ai">${u?a.i:'🔒'}</div><div style="font-weight:700;color:${u?'var(--yl)':'var(--t2)'}">${LANG==='ro'?a.tr:a.te}</div></div>`}).join('')}

function renderCH(){const l=document.getElementById('ch-list');
  l.innerHTML=CHAP.map(c=>{const cm=!!sProg[c.id],pd=c.id===1||!!sProg[c.id-1],lk=!pd&&!cm;
    const fc=c.f?FACS.find(f=>f.id===c.f):null;
    return `<div class="ch ${lk?'lk':''} ${cm?'cm':''}" data-id="${c.id}"><div class="chn">CH.${c.id}</div><div><div class="chnm">${c['n_'+LANG]}${fc?' · <span style="color:'+fc.hex+';font-size:10px">'+fc.n+'</span>':''}</div><div style="font-size:10px;color:var(--t2);margin-top:2px">${LANG==='ro'?'Atinge':'Reach'} ${c.d}m</div></div><div class="chs">${cm?'✓':(lk?'🔒':'▶')}</div></div>`}).join('');
  l.querySelectorAll('.ch:not(.lk)').forEach(el=>el.addEventListener('click',()=>{G.sCh=parseInt(el.dataset.id);hideAll();startG('story')}))}

function renderPR(){document.getElementById('pr-q').textContent=qcores;document.getElementById('pr-l').textContent=prest;document.getElementById('pr-r').textContent=rank();
  document.getElementById('b-doprest').disabled=rank()<10;
  const el=document.getElementById('pr-nodes');
  el.innerHTML=PN.map(n=>{const ow=hasN(n.id),af=qcores>=n.c;
    return `<div class="pn-n ${ow?'ow':(!af?'lk':'')}" data-id="${n.id}"><div class="mdn" style="color:var(--vt)">${n.n}</div><div class="mdd">${n['d_'+LANG]}</div><div class="mdc" style="color:${ow?'var(--gn)':(af?'var(--yl)':'var(--t2)')}">${ow?'✓ ACTIV':n.c+' QC'}</div></div>`}).join('');
  el.querySelectorAll('.pn-n:not(.ow):not(.lk)').forEach(el=>el.addEventListener('click',()=>{const id=el.dataset.id,n=PN.find(x=>x.id===id);if(qcores>=n.c){qcores-=n.c;pNodes[id]=true;S.s('qc',qcores);S.s('pNodes',pNodes);A.mod();toast('⚛ '+n.n,'v');renderPR()}}))}

function doPrest(){if(rank()<10)return;xp=0;G.credits=0;S.s('xp',0);S.s('credits',0);mOwn={};G.mods={};S.s('mods',{});prest++;qcores++;S.s('prest',prest);S.s('qc',qcores);unlock('prst1');A.rk();toast('⚛ PRESTIGE ' + prest,'v');hideAll();show('ov-start');updateAgent()}

function updateAgent(){document.getElementById('ag-r').textContent=rank();document.getElementById('ag-x').textContent=xp;document.getElementById('ag-p').textContent=prest;document.getElementById('ag-q').textContent=qcores;document.getElementById('ag-rn').textContent=runs;document.getElementById('ag-c').textContent=Object.keys(sProg).length+'/12'}

/* ---- Overlay helpers ---- */
function hideAll(){document.querySelectorAll('.ovl').forEach(o=>o.classList.remove('on'))}
function show(id){document.getElementById(id).classList.add('on')}

/* ---- Input ---- */
const keys={};
document.addEventListener('keydown',e=>{keys[e.code]=true;
  if(G.st==='running'){
    if(e.code==='ArrowLeft'||e.code==='KeyA')G.car.ln=Math.max(0,G.car.ln-1);
    if(e.code==='ArrowRight'||e.code==='KeyD')G.car.ln=Math.min(2,G.car.ln+1);
    if(e.code==='Space'){e.preventDefault();if(G.car.bst<=0&&G.credits>=100){G.car.bst=hasM('quantum')?10:5;G.credits-=100;G.bstCount++;toast(t('t_boost'),'c');A.b(880,.2,'sawtooth',.8)}}
    if(e.code==='KeyP'||e.code==='Escape')pauseG();
    if(e.code==='KeyF')document.getElementById('faction-bar').classList.toggle('show');
  }else if(G.st==='paused'&&(e.code==='KeyP'||e.code==='Escape'))resumeG();
});

let tsX=null;
cv.addEventListener('touchstart',e=>{tsX=e.touches[0].clientX},{passive:true});
cv.addEventListener('touchend',e=>{if(G.st!=='running'||tsX===null)return;const dx=e.changedTouches[0].clientX-tsX;if(dx<-30)G.car.ln=Math.max(0,G.car.ln-1);else if(dx>30)G.car.ln=Math.min(2,G.car.ln+1);tsX=null},{passive:true});

document.getElementById('t-l').addEventListener('touchstart',e=>{e.preventDefault();if(G.st==='running')G.car.ln=Math.max(0,G.car.ln-1)},{passive:false});
document.getElementById('t-r').addEventListener('touchstart',e=>{e.preventDefault();if(G.st==='running')G.car.ln=Math.min(2,G.car.ln+1)},{passive:false});
if(window.matchMedia('(hover:none) and (pointer:coarse)').matches)document.getElementById('touch-ctrl').classList.add('show');

/* ---- Wire ---- */
document.getElementById('b-start').addEventListener('click',()=>{A.c();startG('free')});
document.getElementById('b-story').addEventListener('click',()=>{A.c();renderCH();show('ov-story')});
document.getElementById('b-daily').addEventListener('click',()=>{A.c();startG('daily')});
document.getElementById('b-resume').addEventListener('click',()=>{A.c();resumeG()});
document.getElementById('b-quit').addEventListener('click',()=>{A.c();gameOver()});
document.getElementById('b-retry').addEventListener('click',()=>{A.c();startG('free')});
document.getElementById('b-home').addEventListener('click',()=>{A.c();hideAll();G.st='menu';upDaily();updateAgent();show('ov-start')});
document.getElementById('b-share').addEventListener('click',()=>{const tx=`${LANG==='ro'?'Run complet pe NEXUS PROTOCOL v2!':'Complete run on NEXUS PROTOCOL v2!'} 🚀\n${LANG==='ro'?'Scor':'Score'}: ${G.score.toLocaleString()} · ${Math.floor(G.distance)}M\nhttps://laurandreea10.github.io/nexus-protocol/`;if(navigator.share)navigator.share({text:tx}).catch(()=>{});else if(navigator.clipboard){navigator.clipboard.writeText(tx);toast(LANG==='ro'?'Copiat!':'Copied!','c')}});
document.getElementById('b-crm').addEventListener('click',()=>{A.c();contCRM()});
document.getElementById('b-lb').addEventListener('click',()=>{A.c();renderLB('m-lb',null);show('ov-lb')});
document.getElementById('b-lbc').addEventListener('click',()=>{A.c();hideAll();show('ov-start')});
document.getElementById('b-lbr').addEventListener('click',()=>{if(confirm(LANG==='ro'?'Resetează?':'Reset?')){S.s('lb',[]);renderLB('m-lb',null)}});
document.getElementById('b-ach').addEventListener('click',()=>{A.c();renderACH();show('ov-ach')});
document.getElementById('b-achc').addEventListener('click',()=>{A.c();hideAll();show('ov-start')});
document.getElementById('b-storyc').addEventListener('click',()=>{A.c();hideAll();show('ov-start')});
document.getElementById('b-prest').addEventListener('click',()=>{A.c();renderPR();show('ov-prest')});
document.getElementById('b-doprest').addEventListener('click',()=>{A.c();doPrest()});
document.getElementById('b-prestc').addEventListener('click',()=>{A.c();hideAll();show('ov-start')});
document.getElementById('b-factmod').addEventListener('click',()=>{A.c();renderFC();show('ov-fact')});
document.getElementById('b-factc').addEventListener('click',()=>{A.c();hideAll();show('ov-start')});
document.getElementById('b-vendl').addEventListener('click',()=>{A.c();leaveV()});
document.getElementById('b-pause').addEventListener('click',()=>{A.c();if(G.st==='running')pauseG();else if(G.st==='paused')resumeG()});
document.getElementById('b-fac').addEventListener('click',()=>document.getElementById('faction-bar').classList.toggle('show'));
document.getElementById('b-lang').addEventListener('click',()=>{LANG=LANG==='ro'?'en':'ro';localStorage.setItem('nx2.lang',LANG);applyI18n();upDaily();updateAgent()});
document.getElementById('b-sound').addEventListener('click',()=>{A.init();A.tog()});

document.querySelectorAll('.tb[data-tab]').forEach(tb=>{tb.addEventListener('click',()=>{document.querySelectorAll('.tb[data-tab]').forEach(t=>t.classList.remove('on'));document.querySelectorAll('.tc:not(.grid)').forEach(c=>c.classList.remove('on'));tb.classList.add('on');document.getElementById('t-'+tb.dataset.tab).classList.add('on')})});
document.querySelectorAll('.tb[data-tree]').forEach(tb=>{tb.addEventListener('click',()=>{document.querySelectorAll('.tb[data-tree]').forEach(t=>t.classList.remove('on'));document.querySelectorAll('.tc.grid').forEach(c=>c.classList.remove('on'));tb.classList.add('on');document.getElementById('tr-'+tb.dataset.tree).classList.add('on')})});

/* ---- Init ---- */
applyI18n();upDaily();chkStreak();updateAgent();updateFacBar();resize();
if(!A.en)document.getElementById('b-sound').textContent='♪̸';
requestAnimationFrame(loop);
</script>
</body></html>
