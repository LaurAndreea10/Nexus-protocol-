.toast{background:linear-gradient(135deg,rgba(10,15,31,.95),rgba(26,36,86,.85));border:1px solid rgba(57,255,126,.5);color:var(--gn);padding:8px 18px;font-family:var(--fM);font-size:11px;letter-spacing:.08em;text-transform:uppercase;box-shadow:var(--gG);animation:tIn .4s ease,tOut .4s ease 2.6s forwards;white-space:nowrap}
.toast.m{border-color:rgba(255,43,214,.5);color:var(--mg);box-shadow:var(--gM)}
.toast.c{border-color:rgba(0,240,255,.5);color:var(--cy);box-shadow:var(--gC)}
.toast.y{border-color:rgba(255,230,0,.5);color:var(--yl);box-shadow:var(--gY)}
.toast.v{border-color:rgba(138,59,255,.5);color:var(--vt);box-shadow:var(--gV)}
.toast.r{border-color:rgba(255,59,107,.5);color:var(--rd)}
@keyframes tIn{from{opacity:0;transform:translateY(-12px) scale(.96)}to{opacity:1;transform:translateY(0) scale(1)}}
